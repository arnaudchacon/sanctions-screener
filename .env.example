# Supabase project URL (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, bypasses RLS (Project Settings → API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session pooler connection string, port 5432 (Project → Connect → Session pooler)
# The ingestion script will not work on the transaction pooler (port 6543).
DATABASE_URL=postgresql://postgres.your-ref:YOUR_PASSWORD@aws-0-your-region.pooler.supabase.com:5432/postgres
